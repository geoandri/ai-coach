{
  "name": "ai-coach-server",
  "version": "1.0.0",
  "description": "AI Coach standalone Node.js server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/db/migrations', 'dist/db/migrations', {recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^8.1.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "pdfmake": "^0.2.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/pdfmake": "^0.2.9",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}

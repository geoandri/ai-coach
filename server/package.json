{
  "name": "ai-coach-server",
  "version": "1.0.0",
  "description": "AI Coach standalone Node.js server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/db/migrations', 'dist/db/migrations', {recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^8.1.0",
    "axios": "^1.6.0",
    "fastify": "^5.2.1",
    "pdfmake": "^0.2.10",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pdfmake": "^0.2.9",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
